flowchart LR
    Student[Student]
    Owner[Organization Owner]
    Admin[System Admin]
    OAuth[Google OAuth]
    Mail[SMTP Provider]
    Files[Browser / Files]

    subgraph Inputs[External Actors]
        Student
        Owner
        Admin
        OAuth
        Files
    end

    subgraph Core[INVOLVE Major Processes]
        P1((1.0 Account Access))
        P2((2.0 Organization and Membership))
        P3((3.0 Announcements and Activity))
        P4((4.0 Budget and Expense Requests))
        P5((5.0 Financial Transactions))
        P6((6.0 Admin Review and Audit))
        P7((7.0 Reports, Exports, and APIs))
        P8((8.0 Upload Handling))
    end

    subgraph Stores[Data Stores]
        S1[(Accounts and Sessions)]
        S2[(Organizations and Membership)]
        S3[(Announcements and Notifications)]
        S4[(Budgets and Expense Requests)]
        S5[(Transactions and Change Requests)]
        S6[(Audit Logs)]
        S7[(Upload Storage)]
        S8[(Runtime Cache)]
    end

    Student -->|register, login, profile| P1
    Owner -->|login, profile| P1
    Admin -->|login, admin session| P1
    OAuth -->|identity callback| P1
    P1 --> S1
    P1 --> Mail

    Student -->|browse and join| P2
    Owner -->|review members| P2
    Admin -->|manage orgs and owners| P2
    P2 --> S2
    P2 --> S6

    Owner -->|create updates| P3
    Admin -->|manage updates| P3
    Student -->|view activity| P3
    P3 --> S3
    P3 --> S8

    Owner -->|budget lines and expense requests| P4
    Admin -->|approve or reject requests| P4
    P4 --> S4
    P4 --> S5
    P4 --> S3
    P4 --> S6

    Owner -->|record or request changes| P5
    Admin -->|approve transaction changes| P5
    P5 --> S5
    P5 --> S3
    P5 --> S6

    Admin -->|review decisions and logs| P6
    P6 --> S4
    P6 --> S5
    P6 --> S6

    Student -->|dashboard and public reads| P7
    Owner -->|workspace reports| P7
    Admin -->|admin reports and exports| P7
    P7 --> S2
    P7 --> S3
    P7 --> S4
    P7 --> S5
    P7 --> S6
    P7 --> S8
    P7 --> Files

    Student -->|profile photo| P8
    Owner -->|logos and receipts| P8
    Admin -->|organization logos| P8
    Files -->|selected files| P8
    P8 --> S7
    P8 --> S6
