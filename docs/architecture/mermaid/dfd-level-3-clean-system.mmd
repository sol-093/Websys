    subgraph AuthFlow[1.0 Account Access]
        A1((1.1 Register / Login))
        A2((1.2 Verify / Reset Password))
        A3((1.3 Create Session))
        A4((1.4 Complete Onboarding))
    end

    subgraph OrgFlow[2.0 Organization Lifecycle]
        O1((2.1 Browse Organizations))
        O2((2.2 Request Membership))
        O3((2.3 Review Join Request))
        O4((2.4 Assign / Accept Owner))
        O5((2.5 Update Organization Profile))
    end

    subgraph ContentFlow[3.0 Communication]
        C1((3.1 Create Announcement))
        C2((3.2 Pin / Expire Announcement))
        C3((3.3 Build Activity Feed))
    end

    subgraph BudgetFlow[4.0 Budget and Expense Control]
        B1((4.1 Create Budget))
        B2((4.2 Add Budget Lines))
        B3((4.3 Submit Expense Request))
        B4((4.4 Review Expense Request))
        B5((4.5 Create Linked Expense Transaction))
    end

    subgraph FinanceFlow[5.0 Transaction Control]
        F1((5.1 Record Transaction))
        F2((5.2 Request Update / Delete))
        F3((5.3 Review Change Request))
        F4((5.4 Update or Void Transaction))
    end

    subgraph ReportingFlow[6.0 Transparency and Reporting]
        R1((6.1 Load Dashboard Metrics))
        R2((6.2 Serve API Lists))
        R3((6.3 Export PDF / CSV))
        R4((6.4 Review Audit Trail))
    end

