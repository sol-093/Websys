{
  "name": "websys/app",
  "description": "Student Organization Management web application",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "phpmailer/phpmailer": "^6.9"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Involve\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse",
    "doctor": "php scripts/tests/check_requirements.php",
    "lint": "php scripts/tests/lint_php.php",
    "test": "phpunit"
  }
}
